# LookAhead Pro — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Database — SQLite for local dev, Postgres for staging/production
# Local:      DATABASE_URL="file:./prisma/dev.db"
# Postgres:   DATABASE_URL="postgresql://user:pass@host:5432/lookahead?schema=public"
DATABASE_URL="file:./prisma/dev.db"

# Upload directory for schedule files and documents
UPLOAD_DIR="./uploads"

# NextAuth — generate a real secret for staging/production:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-real-secret"
NEXTAUTH_URL="http://localhost:3000"

# AI Analysis (optional) — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
