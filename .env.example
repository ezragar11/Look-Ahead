# LookAhead Pro — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# Database — Postgres (Supabase, Neon, or local)
# Supabase pooled connection (for serverless):
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Supabase direct connection (for migrations):
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase Storage — durable object storage for site plans & documents.
# Required in production: the serverless filesystem is read-only/ephemeral.
# SUPABASE_URL is the project REST URL (Dashboard > Project Settings > API).
# SUPABASE_SERVICE_ROLE_KEY is the service_role secret — server-only, NEVER expose to the client.
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NextAuth — generate a real secret for staging/production:
#   openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-a-real-secret"
NEXTAUTH_URL="http://localhost:3000"

# AI Analysis (optional) — get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
